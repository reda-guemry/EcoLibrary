    "components": {
        "schemas": {
            "Book": {
                "title": "Book",
                "description": "Modèle représentant un livre dans la bibliothèque EcoLibrary",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "Le Petit Prince"
                    },
                    "author": {
                        "type": "string",
                        "example": "Antoine de Saint-Exupéry"
                    },
                    "slug": {
                        "type": "string",
                        "example": "le-petit-prince"
                    },
                    "description": {
                        "type": "string",
                        "example": "Un conte poétique et philosophique sous l'apparence d'un livre pour enfants.",
                        "nullable": true
                    },
                    "total_copies": {
                        "type": "integer",
                        "example": 10
                    },
                    "available_copies": {
                        "type": "integer",
                        "example": 7
                    },
                    "degraded_copies": {
                        "type": "integer",
                        "example": 1
                    },
                    "views": {
                        "type": "integer",
                        "example": 152
                    },
                    "category": {
                        "$ref": "#/components/schemas/Category"
                    }
                },
                "type": "object"
            },
            "Borrow": {
                "title": "Borrow",
                "description": "Modèle représentant un emprunt de livre",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "user_id": {
                        "type": "integer",
                        "example": 3
                    },
                    "book_id": {
                        "type": "integer",
                        "example": 5
                    },
                    "borrowed_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-03-14T10:00:00Z"
                    },
                    "returned_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": null,
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "en cours",
                            "returned"
                        ],
                        "example": "en cours"
                    }
                },
                "type": "object"
            },
            "Category": {
                "title": "Category",
                "description": "Model for book categories",
                "properties": {
                    "id": {
                        "description": "ID of the category",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "Name of the category",
