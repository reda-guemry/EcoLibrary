                "operationId": "f5ca658c501a803d68655af0365e3802",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Identifiant unique du livre à mettre à jour",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Les Misérables - Édition Révisée"
                                    },
                                    "author": {
                                        "type": "string",
                                        "example": "Victor Hugo"
                                    },
                                    "categorie_id": {
                                        "type": "integer",
                                        "example": 3
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Un chef-d'œuvre de la littérature française.",
                                        "nullable": true
                                    },
                                    "total_copies": {
                                        "type": "integer",
                                        "example": 8
                                    },
                                    "available_copies": {
                                        "type": "integer",
                                        "example": 6
                                    },
                                    "degraded_copies": {
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Livre mis à jour avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Book"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Non authentifié - Veuillez vous connecter d'abord"
                    },
                    "403": {
                        "description": "Accès refusé - Réservé aux administrateurs"
                    },
                    "404": {
                        "description": "Livre introuvable"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Books"
                ],
                "summary": "⚠️ Admin Only - Supprimer un livre",
                "description": "Permet à un administrateur de supprimer définitivement un livre de la bibliothèque.",
                "operationId": "1a9c26667c32b8ed5e5770d7a1cc9d5c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Identifiant unique du livre à supprimer",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Livre supprimé avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Book deleted successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Non authentifié - Veuillez vous connecter d'abord"
                    },
                    "403": {
                        "description": "Accès refusé - Réservé aux administrateurs"
                    },
                    "404": {
                        "description": "Livre introuvable"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/books/{bookId}/borrow": {
            "post": {
                "tags": [
                    "Emprunts"
                ],
                "summary": "Emprunter un livre",
                "description": "Permet à un utilisateur authentifié d'emprunter un exemplaire disponible d'un livre. Un utilisateur ne peut pas emprunter le même livre deux fois simultanément.",
                "operationId": "dabcc43ac92762a80673a9faf16eb74c",
                "parameters": [
                    {
                        "name": "bookId",
                        "in": "path",
                        "description": "Identifiant unique du livre à emprunter",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Livre emprunté avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Book borrowed successfully."
                                        },
                                        "borrow": {
                                            "$ref": "#/components/schemas/Borrow"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Impossible d'effectuer l'emprunt (aucun exemplaire disponible ou déjà emprunté)"
                    },
                    "401": {
                        "description": "Non authentifié - Veuillez vous connecter d'abord"
                    },
                    "404": {
                        "description": "Livre introuvable"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/borrows/{borrowId}/return": {
            "post": {
                "tags": [
                    "Emprunts"
                ],
                "summary": "Retourner un livre emprunté",
                "description": "Permet à un utilisateur de restituer un livre qu'il a précédemment emprunté. Seul le propriétaire de l'emprunt peut effectuer cette action.",
                "operationId": "5033941f0ec9d514dc292f86e7b49ee4",
                "parameters": [
                    {
                        "name": "borrowId",
                        "in": "path",
                        "description": "Identifiant unique de l'emprunt à clôturer",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Livre restitué avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Book returned successfully."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Ce livre a déjà été restitué"
                    },
                    "401": {
                        "description": "Non authentifié - Veuillez vous connecter d'abord"
                    },
                    "403": {
                        "description": "Action non autorisée - Cet emprunt ne vous appartient pas"
                    },
                    "404": {
                        "description": "Emprunt introuvable"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
